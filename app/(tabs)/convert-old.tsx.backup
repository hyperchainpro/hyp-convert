        flexDirection: 'row',
        gap: 12,
    },
    uploadButton: {
        flex: 1,
        borderRadius: 16,
        overflow: 'hidden',
    },
    uploadButtonGradient: {
        paddingVertical: 24,
        alignItems: 'center',
        borderRadius: 16,
        borderWidth: 1.5,
        borderColor: 'rgba(0,0,0,0.05)',
        borderStyle: 'dashed',
    },
    uploadButtonText: {
        color: '#000000',
        fontWeight: '600',
        marginTop: 10,
    },
    uploadButtonHint: {
        color: '#8E8E93',
        fontSize: 12,
        marginTop: 4,
    },

    // File Preview
    filePreview: {
        alignItems: 'center',
    },
    imagePreviewContainer: {
        width: '100%',
        height: 180,
        borderRadius: 14,
        overflow: 'hidden',
        backgroundColor: '#F2F2F7',
        marginBottom: 16,
        borderWidth: 1,
        borderColor: '#E5E5EA',
    },
    previewImage: {
        width: '100%',
        height: '100%',
    },
    docPreview: {
        width: '100%',
        height: 100,
        marginBottom: 16,
    },
    docPreviewGradient: {
        flex: 1,
        justifyContent: 'center',
        alignItems: 'center',
        borderRadius: 14,
    },
    fileInfo: {
        alignItems: 'center',
        marginBottom: 12,
    },
    fileName: {
        color: '#1C1C1E',
        fontWeight: '600',
        fontSize: 16,
        marginBottom: 10,
    },
    fileMetaRow: {
        flexDirection: 'row',
        gap: 10,
    },
    chipContainer: {
        flexDirection: 'row',
        alignItems: 'center',
        gap: 6,
        backgroundColor: '#F2F2F7',
        paddingVertical: 6,
        paddingHorizontal: 12,
        borderRadius: 12,
    },
    chipText: {
        color: '#8E8E93',
        fontSize: 13,
    },
    changeFileBtn: {
        paddingVertical: 8,
        paddingHorizontal: 16,
    },
    changeFileBtnText: {
        color: '#007AFF',
        fontWeight: '500',
    },

    // Options Section
    optionsSection: {
        padding: 20,
        borderRadius: 20,
        backgroundColor: '#ffffff',
        marginBottom: 16,
        shadowColor: '#000',
        shadowOffset: { width: 0, height: 2 },
        shadowOpacity: 0.05,
        shadowRadius: 8,
        elevation: 3,
    },
    optionRow: {
        flexDirection: 'row',
        justifyContent: 'space-between',
        alignItems: 'center',
        marginBottom: 16,
    },
    optionLabel: {
        color: '#1C1C1E',
        fontSize: 15,
    },
    menuButton: {
        flexDirection: 'row',
        alignItems: 'center',
        gap: 6,
        backgroundColor: '#F2F2F7',
        paddingVertical: 10,
        paddingHorizontal: 14,
        borderRadius: 10,
    },
    menuButtonText: {
        color: '#000000',
        fontWeight: '500',
    },
    menuContent: {
        backgroundColor: '#ffffff',
        borderRadius: 12,
        elevation: 5,
        shadowColor: '#000',
        shadowOpacity: 0.1,
