{
  "version": 2,
  "public": false,
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(?!.*\\..*$)",
      "dest": "/index.html",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/(.*)",
      "dest": "$1"
    }
  ]
}
